{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "outDir": "./dist",
    "baseUrl": ".",
    "paths": {
      "@holo-js/auth": ["../auth/src/index.ts"],
      "@holo-js/auth-social": ["../auth-social/src/index.ts"],
      "@holo-js/auth-workos": ["../auth-workos/src/index.ts"],
      "@holo-js/auth-clerk": ["../auth-clerk/src/index.ts"],
      "@holo-js/broadcast": ["../broadcast/src/index.ts"],
      "@holo-js/config": ["../config/src/index.ts"],
      "@holo-js/db": ["../db/src/index.ts"],
      "@holo-js/events": ["../events/src/index.ts"],
      "@holo-js/mail": ["../mail/src/index.ts"],
      "@holo-js/notifications": ["../notifications/src/index.ts"],
      "@holo-js/queue": ["../queue/src/index.ts"],
      "@holo-js/queue-db": ["../queue-db/src/index.ts"],
      "@holo-js/security": ["../security/src/index.ts"],
      "@holo-js/security/drivers/redis-adapter": ["../security/src/drivers/redis-adapter.ts"],
      "@holo-js/session": ["../session/src/index.ts"],
      "@holo-js/storage": ["../storage/src/index.ts"],
      "@holo-js/storage/runtime": ["../storage/src/runtime/composables/index.ts"]
    }
  },
  "include": [
    "src/**/*",
    "tests/**/*"
  ],
  "exclude": [
    "node_modules",
    "dist"
  ]
}
