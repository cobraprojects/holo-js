{
  "name": "@holo-js/db",
  "version": "0.1.1",
  "description": "Holo-JS Framework - portable database, ORM, migrations, factories, and seeders",
  "type": "module",
  "license": "MIT",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "default": "./dist/index.mjs"
    }
  },
  "main": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "stub": "tsup --watch",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest --run"
  },
  "dependencies": {
    "better-sqlite3": "^11.7.0",
    "mysql2": "^3.17.1",
    "pg": "^8.13.0",
    "ulid": "^3.0.1",
    "uuid": "^12.0.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "@types/pg": "^8.11.0",
    "tsup": "^8.3.5",
    "typescript": "^5.7.2"
  }
}
