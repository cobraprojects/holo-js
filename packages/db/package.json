{
  "name": "@holo-js/db",
  "version": "0.1.3",
  "description": "Holo-JS Framework - portable database, ORM, migrations, factories, and seeders",
  "type": "module",
  "license": "MIT",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "default": "./dist/index.mjs"
    }
  },
  "main": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "stub": "tsup --watch",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest --run"
  },
  "dependencies": {
    "ulid": "^3.0.1",
    "uuid": "^12.0.0"
  },
  "peerDependencies": {
    "@holo-js/db-mysql": "^0.1.3",
    "@holo-js/db-postgres": "^0.1.3",
    "@holo-js/db-sqlite": "^0.1.3"
  },
  "peerDependenciesMeta": {
    "@holo-js/db-mysql": {
      "optional": true
    },
    "@holo-js/db-postgres": {
      "optional": true
    },
    "@holo-js/db-sqlite": {
      "optional": true
    }
  },
  "devDependencies": {
    "@holo-js/db-mysql": "workspace:*",
    "@holo-js/db-postgres": "workspace:*",
    "@holo-js/db-sqlite": "workspace:*",
    "@types/better-sqlite3": "^7.6.12",
    "@types/pg": "^8.11.0",
    "tsup": "^8.3.5",
    "typescript": "^5.7.2"
  }
}
