{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "outDir": "./dist",
    "baseUrl": ".",
    "paths": {
      "@nuxt/kit": ["./src/nuxt-kit-shim.d.ts"],
      "#app": ["./src/runtime/shims.d.ts"],
      "#imports": ["./src/runtime/shims.d.ts"],
      "@holo-js/forms": ["../forms/src/index.ts"],
      "@holo-js/forms/client": ["../forms/src/client.ts"],
      "@holo-js/validation": ["../validation/src/index.ts"]
    }
  },
  "include": [
    "src/**/*"
  ],
  "exclude": [
    "node_modules",
    "dist"
  ]
}
