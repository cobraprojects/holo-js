{
  "name": "@holo-js/storage",
  "version": "0.1.4",
  "description": "Holo-JS Framework - Portable storage runtime and config helpers",
  "type": "module",
  "license": "MIT",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "default": "./dist/index.mjs"
    },
    "./runtime": {
      "types": "./dist/runtime/composables/index.d.ts",
      "import": "./dist/runtime/composables/index.mjs",
      "default": "./dist/runtime/composables/index.mjs"
    },
    "./runtime/drivers/s3": {
      "types": "./dist/runtime/drivers/s3.d.ts",
      "import": "./dist/runtime/drivers/s3.mjs",
      "default": "./dist/runtime/drivers/s3.mjs"
    }
  },
  "main": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "stub": "tsup",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest --run"
  },
  "dependencies": {
    "@holo-js/config": "^0.1.4"
  },
  "peerDependencies": {
    "@holo-js/storage-s3": "^0.1.4"
  },
  "peerDependenciesMeta": {
    "@holo-js/storage-s3": {
      "optional": true
    }
  },
  "devDependencies": {
    "@holo-js/storage-s3": "workspace:*",
    "@types/node": "^22.10.2",
    "tsup": "^8.3.5",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
