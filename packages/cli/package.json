{
  "name": "@holo-js/cli",
  "version": "0.1.2",
  "description": "Holo-JS Framework - project creation, discovery, and operational CLI",
  "type": "module",
  "license": "MIT",
  "bin": {
    "holo": "./dist/bin/holo.mjs",
    "holo-js": "./dist/bin/holo.mjs"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs"
    }
  },
  "main": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "stub": "tsup --watch",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest --run",
    "test:integration": "HOLO_CLI_INCLUDE_INTEGRATION=1 vitest --run tests/cli.test.ts"
  },
  "dependencies": {
    "@holo-js/config": "^0.1.2",
    "@holo-js/core": "^0.1.2",
    "@holo-js/db": "^0.1.2",
    "esbuild": "^0.27.4"
  },
  "devDependencies": {
    "@holo-js/events": "^0.1.2",
    "@holo-js/queue": "^0.1.2",
    "@holo-js/queue-db": "^0.1.2",
    "@types/node": "^22.10.2",
    "tsup": "^8.3.5",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  },
  "engines": {
    "node": ">=20.11.0"
  }
}
