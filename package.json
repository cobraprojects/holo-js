{
  "name": "holo-js-monorepo",
  "version": "0.0.0",
  "private": true,
  "description": "Holo-JS Framework - configurable backend runtime for Nuxt, Next.js, and SvelteKit",
  "type": "module",
  "workspaces": {
    "packages": [
      "packages/*",
      "apps/*",
      "playground"
    ],
"catalog": {
      "better-sqlite3": "^11.7.0",
      "@types/better-sqlite3": "^7.6.12",
      "nuxt": "^4.0.0",
      "vue": "^3.5.13",
      "vue-router": "^5.0.4",
      "vite": "^5.4.14",
      "@nuxt/kit": "^4.0.0",
      "@nuxt/module-builder": "^1.0.2",
      "@eslint/js": "^9.17.0",
      "@types/node": "^22.10.2",
      "esbuild": "^0.27.4",
      "globals": "^15.14.0",
      "@types/pg": "^8.11.0",
      "mysql2": "^3.17.1",
      "pg": "^8.13.0",
      "ioredis": "^5.4.2",
      "tslib": "^2.8.1",
      "typescript-eslint": "^8.30.1",
      "typescript": "^5.7.2",
      "vue-tsc": "^2.2.0",
      "vitepress": "^1.6.3",
      "vitest": "^2.1.8",
      "tsup": "^8.3.5",
      "eslint": "^9.17.0",
      "fast-check": "^4.5.3",
      "ulid": "^3.0.1",
      "uuid": "^12.0.0"
    }
  },
  "scripts": {
    "dev": "bun run --filter playground dev",
    "dev:docs": "bun --cwd apps/docs dev",
    "build": "bun run --workspaces --if-present --sequential build",
    "build:docs": "bun --cwd apps/docs build",
    "stub": "bun run --workspaces --if-present --sequential stub",
    "lint": "node scripts/run-eslint.mjs && node scripts/run-generated-eslint.mjs",
    "lint:db": "eslint packages/db/src packages/db/tests",
    "lint:fix": "node scripts/run-eslint.mjs --fix && node scripts/run-generated-eslint.mjs --fix",
    "lint:generated": "node scripts/run-generated-eslint.mjs",
    "typecheck": "bun run typecheck:libraries && bun run typecheck:tests",
    "typecheck:libraries": "bun run --workspaces --if-present --sequential typecheck",
    "typecheck:tests": "node scripts/run-test-typecheck.mjs",
    "typecheck:db": "bun run --filter @holo-js/db typecheck",
    "test": "bun run --workspaces --if-present --sequential test",
    "test:watch": "vitest --workspace vitest.workspace.ts",
    "test:db": "vitest --run --project @holo-js/db",
    "test:media": "vitest --run --project @holo-js/media",
    "test:cli": "vitest --run --project @holo-js/cli",
    "test:cli:integration": "bun run --cwd packages/cli test:integration",
    "test:cli:coverage": "rm -rf coverage/cli && HOLO_CLI_INCLUDE_INTEGRATION=1 vitest --run --project @holo-js/cli --coverage --coverage.clean=false --coverage.reportsDirectory='coverage/cli' --coverage.include='packages/cli/src/**/*.ts' --coverage.exclude='packages/cli/src/**/types.ts' --coverage.exclude='packages/cli/src/cli-types.ts' --coverage.exclude='packages/cli/src/bin/**' --pool forks",
    "test:example:blog-nuxt": "bun run --cwd apps/blog-nuxt test",
    "test:example:blog-next": "bun run --cwd apps/blog-next test",
    "test:example:blog-sveltekit": "bun run --cwd apps/blog-sveltekit test",
    "test:examples": "bun run test:example:blog-nuxt && bun run test:example:blog-next && bun run test:example:blog-sveltekit",
    "test:config:coverage": "rm -rf coverage/config && vitest --run --project @holo-js/config --coverage --coverage.clean=false --coverage.reportsDirectory='coverage/config' --coverage.include='packages/config/src/**/*.ts' --coverage.exclude='packages/config/src/**/types.ts'",
    "test:core:coverage": "rm -rf coverage/core && vitest --run --project @holo-js/core --coverage --coverage.clean=false --coverage.reportsDirectory='coverage/core' --coverage.include='packages/core/src/**/*.ts' --coverage.exclude='packages/core/src/**/types.ts' --coverage.exclude='packages/core/src/runtime/**/*.d.ts'",
    "test:db:coverage": "rm -rf coverage/db && vitest --run --project @holo-js/db --coverage --coverage.clean=false --coverage.reportsDirectory='coverage/db' --coverage.include='packages/db/src/**/*.ts' --coverage.exclude='packages/db/src/**/types.ts' --coverage.exclude='packages/db/src/migrations/templates/**' --coverage.exclude='packages/db/src/drivers/index.ts' --coverage.exclude='packages/db/src/drivers/SQLiteAdapter.ts' --coverage.exclude='packages/db/src/drivers/PostgresAdapter.ts' --coverage.exclude='packages/db/src/drivers/MySQLAdapter.ts'",
    "test:events:coverage": "rm -rf coverage/events && vitest --run --project @holo-js/events --coverage --coverage.clean=false --coverage.reportsDirectory='coverage/events' --coverage.include='packages/events/src/**/*.ts' --coverage.exclude='packages/events/src/**/types.ts'",
    "test:queue:coverage": "rm -rf coverage/queue && vitest --run --project @holo-js/queue --coverage --coverage.clean=false --coverage.reportsDirectory='coverage/queue' --coverage.include='packages/queue/src/**/*.ts' --coverage.exclude='packages/queue/src/**/*.d.ts'",
    "test:queue-db:coverage": "rm -rf coverage/queue-db && vitest --run --project @holo-js/queue-db --coverage --coverage.clean=false --coverage.reportsDirectory='coverage/queue-db' --coverage.include='packages/queue-db/src/**/*.ts' --coverage.exclude='packages/queue-db/src/**/*.d.ts'",
    "test:storage:coverage": "rm -rf coverage/storage && vitest --run --project @holo-js/storage --coverage --coverage.clean=false --coverage.reportsDirectory='coverage/storage' --coverage.include='packages/storage/src/**/*.ts' --coverage.exclude='packages/storage/src/**/*.d.ts'",
    "test:adapter-next:coverage": "rm -rf coverage/adapter-next && vitest --run --project @holo-js/adapter-next --coverage --coverage.clean=false --coverage.reportsDirectory='coverage/adapter-next' --coverage.include='packages/adapter-next/src/**/*.ts' --coverage.exclude='packages/adapter-next/src/**/*.d.ts'",
    "test:adapter-nuxt:coverage": "rm -rf coverage/adapter-nuxt && vitest --run --project @holo-js/adapter-nuxt --coverage --coverage.clean=false --coverage.reportsDirectory='coverage/adapter-nuxt' --coverage.include='packages/adapter-nuxt/src/**/*.ts' --coverage.exclude='packages/adapter-nuxt/src/**/*.d.ts'",
    "test:adapter-sveltekit:coverage": "rm -rf coverage/adapter-sveltekit && vitest --run --project @holo-js/adapter-sveltekit --coverage --coverage.clean=false --coverage.reportsDirectory='coverage/adapter-sveltekit' --coverage.include='packages/adapter-sveltekit/src/**/*.ts' --coverage.exclude='packages/adapter-sveltekit/src/**/*.d.ts'",
    "test:broadcast:coverage": "rm -rf coverage/broadcast && vitest --run --project @holo-js/broadcast --coverage --coverage.clean=false --coverage.reportsDirectory='coverage/broadcast' --coverage.include='packages/broadcast/src/**/*.ts' --coverage.exclude='packages/broadcast/src/**/*.d.ts'",
    "test:flux:coverage": "rm -rf coverage/flux && vitest --run --project @holo-js/flux --coverage --coverage.clean=false --coverage.reportsDirectory='coverage/flux' --coverage.include='packages/flux/src/**/*.ts' --coverage.exclude='packages/flux/src/**/*.d.ts'",
    "test:flux-react:coverage": "rm -rf coverage/flux-react && vitest --run --project @holo-js/flux-react --coverage --coverage.clean=false --coverage.reportsDirectory='coverage/flux-react' --coverage.include='packages/flux-react/src/**/*.ts' --coverage.exclude='packages/flux-react/src/**/*.d.ts'",
    "test:flux-vue:coverage": "rm -rf coverage/flux-vue && vitest --run --project @holo-js/flux-vue --coverage --coverage.clean=false --coverage.reportsDirectory='coverage/flux-vue' --coverage.include='packages/flux-vue/src/**/*.ts' --coverage.exclude='packages/flux-vue/src/**/*.d.ts'",
    "test:flux-svelte:coverage": "rm -rf coverage/flux-svelte && vitest --run --project @holo-js/flux-svelte --coverage --coverage.clean=false --coverage.reportsDirectory='coverage/flux-svelte' --coverage.include='packages/flux-svelte/src/**/*.ts' --coverage.exclude='packages/flux-svelte/src/**/*.d.ts'",
    "test:auth:coverage": "rm -rf coverage/auth && vitest --run --project @holo-js/auth --coverage --coverage.clean=false --coverage.reportsDirectory='coverage/auth' --coverage.include='packages/auth/src/**/*.ts'",
    "test:auth-social:coverage": "rm -rf coverage/auth-social && vitest --run --project @holo-js/auth-social --coverage --coverage.clean=false --coverage.reportsDirectory='coverage/auth-social' --coverage.include='packages/auth-social/src/**/*.ts'",
    "test:auth-workos:coverage": "rm -rf coverage/auth-workos && vitest --run --project @holo-js/auth-workos --coverage --coverage.clean=false --coverage.reportsDirectory='coverage/auth-workos' --coverage.include='packages/auth-workos/src/**/*.ts'",
    "test:auth-clerk:coverage": "rm -rf coverage/auth-clerk && vitest --run --project @holo-js/auth-clerk --coverage --coverage.clean=false --coverage.reportsDirectory='coverage/auth-clerk' --coverage.include='packages/auth-clerk/src/**/*.ts'",
    "test:forms:coverage": "rm -rf coverage/forms && vitest --run --project @holo-js/forms --coverage --coverage.clean=false --coverage.reportsDirectory='coverage/forms' --coverage.include='packages/forms/src/**/*.ts' --coverage.exclude='packages/forms/src/**/*.d.ts'",
    "test:media:coverage": "rm -rf coverage/media && vitest --run --project @holo-js/media --coverage --coverage.clean=false --coverage.reportsDirectory='coverage/media' --coverage.include='packages/media/src/**/*.ts' --coverage.exclude='packages/media/src/**/*.d.ts'",
    "test:session:coverage": "rm -rf coverage/session && vitest --run --project @holo-js/session --coverage --coverage.clean=false --coverage.reportsDirectory='coverage/session' --coverage.include='packages/session/src/**/*.ts'",
    "test:validation:coverage": "rm -rf coverage/validation && vitest --run --project @holo-js/validation --coverage --coverage.clean=false --coverage.reportsDirectory='coverage/validation' --coverage.include='packages/validation/src/**/*.ts' --coverage.exclude='packages/validation/src/**/*.d.ts'",
    "check:db": "bun run typecheck:db && bun run lint:db && bun run test:db && bun run test:db:coverage",
    "test:smoke:frameworks": "node scripts/validate-framework-smoke.mjs",
    "test:coverage": "node scripts/run-coverage.mjs",
    "migrate": "holo migrate",
    "migrate:fresh": "holo migrate:fresh",
    "migrate:rollback": "holo migrate:rollback",
    "seed": "holo seed",
    "prune": "holo prune",
    "commands": "holo list",
    "make:migration": "holo make:migration",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "bun run build && changeset publish",
    "clean": "rm -rf node_modules packages/*/node_modules apps/*/node_modules playground/node_modules packages/*/dist apps/*/dist playground/.output .nuxt apps/*/.nuxt playground/.nuxt"
  },
  "devDependencies": {
    "@changesets/cli": "^2.30.0",
    "@eslint/js": "catalog:",
    "@types/better-sqlite3": "catalog:",
    "@vitest/coverage-istanbul": "2.1.9",
    "@vitest/coverage-v8": "^2.1.9",
    "better-sqlite3": "catalog:",
    "eslint": "catalog:",
    "fast-check": "catalog:",
    "globals": "catalog:",
    "@holo-js/cli": "workspace:*",
    "mysql2": "catalog:",
    "pg": "catalog:",
    "typescript": "catalog:",
    "typescript-eslint": "catalog:",
    "ulid": "catalog:",
    "uuid": "catalog:",
    "vitest": "catalog:"
  },
  "engines": {
    "node": ">=20.11.0"
  },
  "packageManager": "bun@1.3.9",
  "trustedDependencies": [
    "better-sqlite3",
    "sharp"
  ]
}
