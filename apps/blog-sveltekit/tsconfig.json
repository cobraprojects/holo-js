{
  "extends": "./.svelte-kit/tsconfig.json",
  "compilerOptions": {
    "strict": true,
    "noEmit": true,
    "skipLibCheck": true
  },
  "include": [
    "src/**/*.ts",
    "src/**/*.svelte",
    "server/**/*.ts",
    "config/**/*.ts",
    ".holo-js/generated/**/*.ts",
    ".holo-js/generated/**/*.d.ts",
    "vite.config.ts"
  ]
}
