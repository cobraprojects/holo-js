    "@holo-js/auth-social-google": "^0.1.4",
    "@holo-js/auth-workos": "^0.1.4",
    "@holo-js/authorization": "^0.1.4",
    "@holo-js/broadcast": "^0.1.4",
    "@holo-js/cache": "^0.1.4",
    "@holo-js/cache-db": "^0.1.4",
